{
  "uid": "db-postgres",
  "title": "DB / Postgres",
  "tags": ["postgres", "db"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Connections",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": ""
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Transactions",
      "gridPos": { "x": 6, "y": 0, "w": 9, "h": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit[5m])",
          "legendFormat": "commits"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback[5m])",
          "legendFormat": "rollbacks"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connections (by db)",
      "gridPos": { "x": 15, "y": 0, "w": 9, "h": 8 },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_hit[5m])) + sum(rate(pg_stat_database_blks_read[5m])))",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Row Activity",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_tup_inserted[5m]))",
          "legendFormat": "inserted"
        },
        {
          "expr": "sum(rate(pg_stat_database_tup_updated[5m]))",
          "legendFormat": "updated"
        },
        {
          "expr": "sum(rate(pg_stat_database_tup_deleted[5m]))",
          "legendFormat": "deleted"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" }
}
